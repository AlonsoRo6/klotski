<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">

  <!-- property keys -->
  <key id="key0" for="node" attr.name="is_goal" attr.type="boolean" />
  <key id="key1" for="node" attr.name="is_start" attr.type="boolean" />
  <key id="key2" for="graph" attr.name="puzzle" attr.type="string" />
  <key id="key3" for="node" attr.name="state" attr.type="string" />

  <graph id="G" edgedefault="undirected" parse.nodeids="canonical" parse.edgeids="canonical" parse.order="nodesfirst">

   <!-- graph properties -->
   <data key="key2">{&quot;W&quot;: 3, &quot;H&quot;: 3, &quot;walls&quot;: [], &quot;pieces&quot;: [[[0, 0]]], &quot;start&quot;: [[1, 1]], &quot;goals&quot;: [{&quot;i&quot;: 0, &quot;pos&quot;: [1, 0]}]}</data>

   <!-- vertices -->
    <node id="n0">
      <data key="key0">0</data>
      <data key="key1">1</data>
      <data key="key3">1,1</data>
    </node>
    <node id="n1">
      <data key="key0">1</data>
      <data key="key1">0</data>
      <data key="key3">1,0</data>
    </node>
    <node id="n2">
      <data key="key0">0</data>
      <data key="key1">0</data>
      <data key="key3">2,1</data>
    </node>
    <node id="n3">
      <data key="key0">0</data>
      <data key="key1">0</data>
      <data key="key3">1,2</data>
    </node>
    <node id="n4">
      <data key="key0">0</data>
      <data key="key1">0</data>
      <data key="key3">0,1</data>
    </node>
    <node id="n5">
      <data key="key0">0</data>
      <data key="key1">0</data>
      <data key="key3">0,0</data>
    </node>
    <node id="n6">
      <data key="key0">0</data>
      <data key="key1">0</data>
      <data key="key3">0,2</data>
    </node>
    <node id="n7">
      <data key="key0">0</data>
      <data key="key1">0</data>
      <data key="key3">2,2</data>
    </node>
    <node id="n8">
      <data key="key0">0</data>
      <data key="key1">0</data>
      <data key="key3">2,0</data>
    </node>

   <!-- edges -->
    <edge id="e0" source="n0" target="n1">
    </edge>
    <edge id="e1" source="n0" target="n2">
    </edge>
    <edge id="e2" source="n0" target="n3">
    </edge>
    <edge id="e3" source="n0" target="n4">
    </edge>
    <edge id="e4" source="n2" target="n8">
    </edge>
    <edge id="e5" source="n3" target="n7">
    </edge>
    <edge id="e6" source="n4" target="n5">
    </edge>
    <edge id="e7" source="n4" target="n6">
    </edge>
    <edge id="e8" source="n5" target="n1">
    </edge>
    <edge id="e9" source="n6" target="n3">
    </edge>
    <edge id="e10" source="n7" target="n2">
    </edge>
    <edge id="e11" source="n8" target="n1">
    </edge>

  </graph>
</graphml>
